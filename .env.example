# Supabase (required for multi-device sync, optional for local-only mode)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (for card payments via Payment Links)
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your-payment-link-id

# PayPal (for PayPal Smart Buttons — client ID is public)
VITE_PAYPAL_CLIENT_ID=your-paypal-client-id

# Supabase Edge Function secrets (set in Supabase Dashboard, NOT here):
# STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET
# PAYPAL_CLIENT_ID, PAYPAL_CLIENT_SECRET, PAYPAL_MODE (sandbox/live)
